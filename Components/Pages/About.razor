@page "/about"
<PageTitle>About Us | Pensoft Systems</PageTitle>

<div class="relative min-h-[40vh] flex items-center pt-20 pb-16 overflow-hidden bg-fixed bg-cover bg-center"
     style="background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop');">
    <div class="absolute inset-0 bg-gradient-to-r from-[#0f1c35]/95 via-[#0f1c35]/85 to-[#0f1c35]/60 z-0"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 80% 20%, #f97316 1%, transparent 30%);"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-10 w-full relative z-10">
        <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight mb-4">About Us</h1>
        <div class="h-1.5 w-24 bg-orange-500 rounded-full"></div>
    </div>
</div>

<div class="py-16 lg:py-24 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto">

        <p class="text-orange-500 font-bold tracking-widest uppercase mb-6 text-sm animate-fade-in">African Based Company</p>

        <div class="mb-24 relative">
            <div class="bg-white/80 backdrop-blur-md p-8 md:p-12 rounded-[2rem] border border-white shadow-xl relative overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-orange-500/5 rounded-bl-full"></div>
                <div class="relative z-10">
                    <p class="text-xl text-slate-700 leading-relaxed font-medium max-w-5xl">
                        An innovative software development, IT Services, Engineering and Management Consulting Company domiciled in Kenya.
                        Our methodology and processes constantly deliver improved results for our customers to stay ahead of their competitors.
                        As a professionally managed company, we provide best of breed service to our customers which transform their business.
                    </p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-20 mb-20">
            <div class="bg-white/70 backdrop-blur-md p-8 pt-16 rounded-3xl border border-white shadow-lg relative group hover:-translate-y-2 transition-all duration-300">
                <div class="absolute -top-10 left-8 h-20 w-20 bg-orange-500 rounded-2xl flex justify-center items-center rotate-3 group-hover:rotate-0 transition-transform duration-300 shadow-lg shadow-orange-500/30 border-4 border-white">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Our Vision</h3>
                <p class="text-slate-600 leading-relaxed">The knowledge based solutions provider for the African Region.</p>
            </div>

            <div class="bg-white/70 backdrop-blur-md p-8 pt-16 rounded-3xl border border-white shadow-lg relative group hover:-translate-y-2 transition-all duration-300">
                <div class="absolute -top-10 left-8 h-20 w-20 bg-slate-900 rounded-2xl flex justify-center items-center -rotate-3 group-hover:rotate-0 transition-transform duration-300 shadow-lg shadow-black/20 border-4 border-white">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Our Mission</h3>
                <p class="text-slate-600 leading-relaxed">Delighting all stakeholders through Solutions in; Software, Engineering, Healthcare and Consulting.</p>
            </div>

            <div class="bg-white/70 backdrop-blur-md p-8 pt-16 rounded-3xl border border-white shadow-lg relative group hover:-translate-y-2 transition-all duration-300">
                <div class="absolute -top-10 left-8 h-20 w-20 bg-orange-500 rounded-2xl flex justify-center items-center rotate-6 group-hover:rotate-0 transition-transform duration-300 shadow-lg shadow-orange-500/30 border-4 border-white">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-1.447-.894L15 7m0 10V7" /></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4">Our Plan</h3>
                <p class="text-slate-600 leading-relaxed">To improve productivity, reduce operating costs and risk, and optimize IT infrastructure and processes.</p>
            </div>
        </div>

        <div class="flex justify-center mb-24">
            <div class="w-full max-w-4xl bg-[#0f1c35] p-10 pt-16 rounded-3xl shadow-2xl relative group border border-white/10 text-center">

                <div class="absolute inset-0 rounded-3xl overflow-hidden pointer-events-none z-0">
                    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 20px 20px;"></div>
                </div>

                <div class="absolute -top-10 left-1/2 -translate-x-1/2 h-20 w-20 bg-white rounded-2xl flex justify-center items-center rotate-2 group-hover:rotate-0 transition-transform duration-300 shadow-lg border-4 border-[#0f1c35] z-20">
                    <svg class="w-10 h-10 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </div>

                <h3 class="text-3xl font-bold text-white mb-8 relative z-10">Our Core Values</h3>
                <div class="flex flex-wrap justify-center gap-4 relative z-10">
                    @foreach (var value in new[] { "Integrity", "Professionalism", "Innovation", "Teamwork", "Responsiveness", "Competitiveness" })
                    {
                        <span class="bg-white/5 backdrop-blur-sm border border-white/10 text-orange-400 px-6 py-2 rounded-xl text-base font-bold hover:bg-orange-500 hover:text-white hover:border-orange-500 transition-all cursor-default">@value</span>
                    }
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 h-[600px]">
            <div class="md:col-span-8 rounded-3xl overflow-hidden relative group border border-white shadow-lg">
                <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=2071&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Team Work" />
            </div>
            <div class="md:col-span-4 flex flex-col gap-4">
                <div class="h-1/2 rounded-3xl overflow-hidden relative group border border-white shadow-lg">
                    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Office" />
                </div>
                <div class="h-1/2 rounded-3xl overflow-hidden relative group border border-white shadow-lg">
                    <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Innovation" />
                </div>
            </div>
        </div>

    </div>
</div>
