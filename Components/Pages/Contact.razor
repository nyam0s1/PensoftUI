@page "/contact"
<PageTitle>Contact Us | Pensoft Systems</PageTitle>

<div class="bg-[#0f1c35] text-white py-16 px-6 sm:px-10 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 80% 20%, #f97316 1%, transparent 30%);"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <p class="text-orange-500 font-bold tracking-widest uppercase mb-2 text-sm">Get In Touch</p>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">Contact Us</h1>
    </div>
</div>

<div class="bg-gray-50 min-h-screen py-16 lg:py-24 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

            <div class="flex flex-col gap-8">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-4">Let's start a conversation.</h2>
                    <p class="text-lg text-slate-600 leading-relaxed">
                        Whether you are looking to revamp your enterprise architecture or explore cutting-edge RPA and Blockchain solutions, our team is ready to help.
                    </p>
                </div>

                <div class="flex flex-col gap-6 mt-4">

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900">Location</h4>
                            <p class="text-slate-600">Northstar Building, Lenana Road</p>
                            <p class="text-slate-600">Kilimani, Nairobi</p>
                            <p class="text-slate-500 text-sm mt-1">P.O. Box 52624-00100, Nairobi Kenya</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900">Email</h4>
                            <a href="mailto:info@pensoft.co.ke" class="text-orange-500 hover:text-orange-600 transition-colors font-medium">info@pensoft.co.ke</a>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900">Call Us</h4>
                            <p class="text-slate-600">+254 20 216 3762</p>
                            <p class="text-slate-600">+254 702 401 960</p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="bg-white p-8 md:p-10 rounded-2xl shadow-sm border border-slate-100 h-fit">
                <h3 class="text-2xl font-bold text-slate-900 mb-6">Send a Message</h3>

                <form class="flex flex-col gap-5">

                    <div class="flex flex-col gap-1">
                        <label for="name" class="text-sm font-semibold text-slate-700">Full Name</label>
                        <input type="text" id="name" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none transition-all" placeholder="John Doe" />
                    </div>

                    <div class="flex flex-col gap-1">
                        <label for="email" class="text-sm font-semibold text-slate-700">Email Address</label>
                        <input type="email" id="email" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none transition-all" placeholder="john@company.com" />
                    </div>

                    <div class="flex flex-col gap-1">
                        <label for="subject" class="text-sm font-semibold text-slate-700">Subject</label>
                        <input type="text" id="subject" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none transition-all" placeholder="How can we help you?" />
                    </div>

                    <div class="flex flex-col gap-1">
                        <label for="message" class="text-sm font-semibold text-slate-700">Message</label>
                        <textarea id="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 outline-none transition-all resize-none" placeholder="Write your message here..."></textarea>
                    </div>

                    <button type="button" class="mt-2 w-full bg-orange-500 text-white font-bold text-lg py-4 rounded-lg hover:bg-orange-600 transition-colors shadow-md shadow-orange-500/20">
                        Send Message
                    </button>

                </form>
            </div>

        </div>
    </div>
</div>