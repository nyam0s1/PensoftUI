@page "/contact"
<PageTitle>Contact Us | Pensoft Systems</PageTitle>

<div class="relative min-h-[40vh] flex items-center pt-20 pb-16 overflow-hidden bg-fixed bg-cover bg-center" 
     style="background-image: url('https://images.unsplash.com/photo-1516387938699-a93567102ce3?q=80&w=2070&auto=format&fit=crop');">
    <div class="absolute inset-0 bg-gradient-to-r from-[#0f1c35]/95 via-[#0f1c35]/85 to-[#0f1c35]/60 z-0"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 80% 20%, #f97316 1%, transparent 30%);"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-10 w-full relative z-10">
        <p class="text-orange-500 font-bold tracking-widest uppercase mb-4 text-sm animate-fade-in">Get In Touch</p>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight mb-4">Contact Us</h1>
        <div class="h-1.5 w-24 bg-orange-500 rounded-full"></div>
    </div>
</div>

<div class="py-16 lg:py-24 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto flex flex-col gap-16">

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
            
            <div class="flex flex-col gap-8">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-4">Let's start a conversation.</h2>
                    <p class="text-lg text-slate-700 leading-relaxed font-medium">
                        Whether you are looking to revamp your enterprise architecture or explore cutting-edge RPA and Blockchain solutions, our team is ready to help.
                    </p>
                </div>

                <div class="flex flex-col gap-6 mt-4">
                    <div class="flex items-start gap-4 bg-white/60 backdrop-blur-sm p-6 rounded-2xl border border-white shadow-sm hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 mb-1">Location</h4>
                            <p class="text-slate-600">Ground Floor, Northstar Building</p>
                            <p class="text-slate-600">Lenana Road, Kilimani, Nairobi</p>
                            <p class="text-slate-500 text-sm mt-2 font-medium">P.O. Box 52624-00100, Nairobi Kenya</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4 bg-white/60 backdrop-blur-sm p-6 rounded-2xl border border-white shadow-sm hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 mb-1">Email</h4>
                            <a href="mailto:info@pensoft.co.ke" class="text-orange-500 hover:text-orange-600 transition-colors font-semibold">info@pensoft.co.ke</a>
                        </div>
                    </div>

                    <div class="flex items-start gap-4 bg-white/60 backdrop-blur-sm p-6 rounded-2xl border border-white shadow-sm hover:shadow-md transition-shadow">
                        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0 text-orange-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 mb-1">Call Us</h4>
                            <p class="text-slate-600 font-medium hover:text-orange-500 transition-colors cursor-pointer">+254 20 216 3762</p>
                            <p class="text-slate-600 font-medium hover:text-orange-500 transition-colors cursor-pointer">+254 702 401 960</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white/80 backdrop-blur-md p-8 md:p-10 rounded-3xl shadow-lg border border-white h-fit">
                <h3 class="text-2xl font-bold text-slate-900 mb-6">Send a Message</h3>

                <form class="flex flex-col gap-5">
                    <div class="flex flex-col gap-1.5">
                        <label for="name" class="text-sm font-bold text-slate-700">Full Name</label>
                        <input type="text" id="name" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 bg-white/50 focus:bg-white focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all" placeholder="John Doe" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="email" class="text-sm font-bold text-slate-700">Email Address</label>
                        <input type="email" id="email" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 bg-white/50 focus:bg-white focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all" placeholder="john@company.com" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="subject" class="text-sm font-bold text-slate-700">Subject</label>
                        <input type="text" id="subject" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 bg-white/50 focus:bg-white focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all" placeholder="How can we help you?" />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="message" class="text-sm font-bold text-slate-700">Message</label>
                        <textarea id="message" rows="4" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 bg-white/50 focus:bg-white focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all resize-none" placeholder="Write your message here..."></textarea>
                    </div>

                    <button type="button" class="mt-4 w-full bg-orange-500 text-white font-bold text-lg py-4 rounded-xl hover:bg-orange-600 transition-colors shadow-lg shadow-orange-500/30 flex justify-center items-center gap-2 group">
                        Send Message
                        <svg class="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </form>
            </div>
        </div>

        <div class="relative flex items-center justify-center mt-8 mb-4">
            <div class="absolute inset-x-8 md:inset-x-16 h-px bg-[#0f1c35]/10"></div>
            
            <div class="relative w-14 h-14 bg-[#f3ebdc] rounded-full border-2 border-orange-200 flex items-center justify-center text-orange-500 z-10 shadow-sm animate-bounce-slow">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
            </div>
        </div>

        <div class="flex flex-col gap-8">
            <div class="text-center">
                <h3 class="text-3xl font-bold text-slate-900 mb-2">Our Location</h3>
                <p class="text-lg text-slate-600 font-medium">Drop by our offices at Northstar Building, Ground Floor.</p>
            </div>
            
            <div class="w-full lg:w-[80%] mx-auto h-[380px] md:h-[480px] rounded-3xl overflow-hidden shadow-xl border-4 border-white relative group">
                <div class="absolute inset-0 bg-slate-100 animate-pulse -z-10"></div>
                
                <iframe 
                    src="https://maps.google.com/maps?q=Northstar%20Building,%20Lenana%20Road,%20Nairobi&t=&z=15&ie=UTF8&iwloc=&output=embed" 
                    class="w-full h-full border-0 grayscale group-hover:grayscale-0 transition-all duration-700" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>

    </div>
</div>

<style>
    /* Smooth, subtle bounce for the arrow */
    @@keyframes bounce-slow {
        0%, 100% {
            transform: translateY(-15%);
            animation-timing-function: cubic-bezier(0.8, 0, 1, 1);
        }
        50% {
            transform: translateY(15%);
            animation-timing-function: cubic-bezier(0, 0, 0.2, 1);
        }
    }
    
    .animate-bounce-slow {
        animation: bounce-slow 3s infinite;
    }
</style>