    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("observeImpactSection", objRef);
            await JS.InvokeVoidAsync("initScrollReveals");
            await JS.InvokeVoidAsync("startTestimonialProgress", TestimonialIntervalMs);

            testimonialTimer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(async () =>
                {
                    activeTestimonial = (activeTestimonial + 1) % testimonials.Count;
                    StateHasChanged();
                    try { await JS.InvokeVoidAsync("startTestimonialProgress", TestimonialIntervalMs); }
                    catch { }
                });
            }, null, TestimonialIntervalMs, TestimonialIntervalMs);
        }
    }

    private async Task SelectTestimonial(int index)
    {
        if (index == activeTestimonial) return;
        activeTestimonial = index;
        testimonialTimer?.Change(TestimonialIntervalMs, TestimonialIntervalMs);
        try { await JS.InvokeVoidAsync("startTestimonialProgress", TestimonialIntervalMs); } catch { }
        StateHasChanged();
    }

    [JSInvokable]
    public async Task StartAnimation()
    {
        if (hasAnimated) return;
        hasAnimated = true;
        for (int i = 0; i <= 100; i++)
        {
            if (years < 15) years++;
            if (systems < 50) systems += 2;
            if (percentage < 100) percentage += 4;
            if (systems > 50) systems = 50;
            if (percentage > 100) percentage = 100;
            StateHasChanged();
            await Task.Delay(25);
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
        testimonialTimer?.Dispose();
    }
}