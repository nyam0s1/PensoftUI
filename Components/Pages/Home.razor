<style>
    /* Let's remove the @@import since we are using HeadContent now */

    html, body {
        scroll-behavior: smooth;
        font-family: 'Plus Jakarta Sans', sans-serif !important; /* Adding !important to force it over defaults */
    }

    .scroll-reveal {
        opacity: 0;
        transform: translateY(60px);
        transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .scroll-reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-marquee {
        animation: marquee 40s linear infinite;
    }

    .marquee-wrapper:hover .animate-marquee {
        animation-play-state: paused;
    }

    @@keyframes marquee {
        0% {
            transform: translateX(0%);
        }

        100% {
            transform: translateX(-50%);
        }
    }
</style>

@code {
    private int years = 0;
    private int systems = 0;
    private int percentage = 0;
    private bool hasAnimated = false;
    private DotNetObjectReference<Home>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("observeImpactSection", objRef);
            await JS.InvokeVoidAsync("initScrollReveals");
        }
    }

    [JSInvokable]
    public async Task StartAnimation()
    {
        if (hasAnimated) return;
        hasAnimated = true;

        for (int i = 0; i <= 100; i++)
        {
            if (years < 15) years++;
            if (systems < 50) systems += 2;
            if (percentage < 100) percentage += 4;

            if (systems > 50) systems = 50;
            if (percentage > 100) percentage = 100;

            StateHasChanged();
            await Task.Delay(25);
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}

<script>
    window.observeImpactSection = (dotnetHelper) => {
        const section = document.getElementById('impact-section');
        if (!section) return;

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    dotnetHelper.invokeMethodAsync('StartAnimation');
                    observer.unobserve(section);
                }
            });
        }, { threshold: 0.3 });

        observer.observe(section);
    };

    window.initScrollReveals = () => {
        const revealElements = document.querySelectorAll('.scroll-reveal');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        revealElements.forEach(el => revealObserver.observe(el));
    };
</script>