@page "/services"
<PageTitle>Services | Pensoft Systems</PageTitle>

<div class="bg-[#0f1c35] text-white py-16 px-6 sm:px-10 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 80% 20%, #f97316 1%, transparent 30%);"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <p class="text-orange-500 font-bold tracking-widest uppercase mb-2 text-sm">What We Do</p>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">Our Services</h1>
    </div>
</div>

<div class="bg-gray-50 min-h-screen py-16 lg:py-24 px-6 sm:px-10">
    <div class="max-w-7xl mx-auto">

        <div class="max-w-3xl mb-16">
            <p class="text-xl text-slate-700 leading-relaxed font-medium">
                Our service offering portfolio delivers reliable and innovative technology solutions that provide real business value. We ensure your enterprise operates efficiently and stays ahead of the curve.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            <div class="bg-white p-10 rounded-xl shadow-sm border-t-4 border-orange-500 hover:shadow-lg hover:-translate-y-2 transition-all duration-300 group">
                <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-orange-500 transition-colors duration-300">
                    <svg class="w-8 h-8 text-orange-500 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-orange-500 transition-colors">Software Development</h3>
                <p class="text-slate-600 leading-relaxed">
                    Software development takes high-level technical knowledge and organized, experienced development teams to succeed.
                </p>
            </div>

            <div class="bg-white p-10 rounded-xl shadow-sm border-t-4 border-orange-500 hover:shadow-lg hover:-translate-y-2 transition-all duration-300 group">
                <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-orange-500 transition-colors duration-300">
                    <svg class="w-8 h-8 text-orange-500 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-orange-500 transition-colors">Consultancy</h3>
                <p class="text-slate-600 leading-relaxed">
                    We are determined to harness the information you need to offer a greater customer value and create new business opportunities.
                </p>
            </div>

            <div class="bg-white p-10 rounded-xl shadow-sm border-t-4 border-orange-500 hover:shadow-lg hover:-translate-y-2 transition-all duration-300 group">
                <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-orange-500 transition-colors duration-300">
                    <svg class="w-8 h-8 text-orange-500 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-orange-500 transition-colors">System Integration</h3>
                <p class="text-slate-600 leading-relaxed">
                    System integration is about adding value to the system, capabilities that are possible because of interactions between subsystems.
                </p>
            </div>

        </div>
    </div>
</div>